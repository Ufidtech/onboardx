PORT=4000

# AI provider: using Azure OpenAI (via AI Foundry) since Gemini free tier quota ran out.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Gemini key kept here in case you switch back later
GEMINI_API_KEY=

# Either place a service-account.json file in this folder (see services/firebaseAdmin.js)
# or set this instead when deploying:
FIREBASE_SERVICE_ACCOUNT=
